<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane styleClass="app-shell" xmlns="http://javafx.com/javafx/11.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.sab.winery.controller.LoginController">
   <top>
      <VBox spacing="2.0" styleClass="topbar">
         <children>
            <Label styleClass="app-title" text="WineryTours" />
            <Label styleClass="app-subtitle" text="Авторизація для доступу до системи дегустаційних турів" />
         </children>
      </VBox>
   </top>
   <center>
      <StackPane>
         <padding>
            <Insets bottom="30" left="30" right="30" top="30" />
         </padding>
         <children>
            <VBox spacing="14.0" styleClass="login-card">
               <children>
                  <Label styleClass="section-title" text="Вхід у WineryTours" />
                  <Label styleClass="section-subtitle"
                         text="Введіть облікові дані, щоб продовжити роботу з системою турів виноробні"
                         wrapText="true" />
                  <Separator />
                  <GridPane hgap="10.0" vgap="12.0">
                     <columnConstraints>
                        <ColumnConstraints hgrow="NEVER" minWidth="100.0" />
                        <ColumnConstraints hgrow="ALWAYS" />
                     </columnConstraints>
                     <children>
                        <Label text="Логін:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <TextField fx:id="usernameField" promptText="Введіть логін"
                                   GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        <Label text="Пароль:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <PasswordField fx:id="passwordField" promptText="Введіть пароль"
                                       GridPane.columnIndex="1" GridPane.rowIndex="1" />
                     </children>
                  </GridPane>
                  <HBox alignment="CENTER_RIGHT" spacing="10.0">
                     <children>
                        <Button defaultButton="true" mnemonicParsing="false"
                                onAction="#handleLogin" styleClass="btn-primary"
                                text="Увійти" />
                     </children>
                  </HBox>
                  <Label styleClass="app-subtitle"
                         text="Початковий адміністратор: admin / admin123"
                         wrapText="true" />
               </children>
            </VBox>
         </children>
      </StackPane>
   </center>
   <bottom>
      <HBox alignment="CENTER" styleClass="footer-bar">
         <children>
            <Label styleClass="footer-label"
                   text="WineryTours · дегустаційні тури · локальна база winery.db" />
         </children>
      </HBox>
   </bottom>
</BorderPane>
