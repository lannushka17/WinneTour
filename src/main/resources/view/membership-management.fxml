<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.sab.winery.controller.MembershipController">
   <top>
      <VBox spacing="6.0" styleClass="page-wrap">
         <children>
            <Label styleClass="section-title" text="Клуб виноробні — лояльність гостей" />
            <Label styleClass="section-subtitle"
                   text="Картки гостей з рівнями знижок і термінами дії" />
            <Separator />
         </children>
      </VBox>
   </top>
   <center>
      <SplitPane dividerPositions="0.62" orientation="VERTICAL">
         <items>
            <VBox spacing="10.0" styleClass="section-card">
               <children>
                  <HBox styleClass="toolbar-row">
                     <children>
                        <Label styleClass="label-strong" text="Картки клубу" />
                        <Region HBox.hgrow="ALWAYS" />
                        <ComboBox fx:id="statusFilter" promptText="Фільтр за статусом" />
                        <Button mnemonicParsing="false" onAction="#handleRefresh"
                                styleClass="btn-neutral" text="Оновити" />
                     </children>
                  </HBox>
                  <TableView fx:id="membershipTable" VBox.vgrow="ALWAYS">
                     <columns>
                        <TableColumn fx:id="idColumn" prefWidth="55.0" text="ID" />
                        <TableColumn fx:id="guestColumn" prefWidth="200.0" text="Гість" />
                        <TableColumn fx:id="tierColumn" prefWidth="130.0" text="Рівень" />
                        <TableColumn fx:id="validColumn" prefWidth="120.0" text="Діє до" />
                        <TableColumn fx:id="discountColumn" prefWidth="100.0" text="Знижка, %" />
                        <TableColumn fx:id="activeColumn" prefWidth="110.0" text="Статус" />
                     </columns>
                  </TableView>
               </children>
            </VBox>
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="content-scroll" vbarPolicy="AS_NEEDED">
               <content>
                  <VBox spacing="15.0" styleClass="section-card">
                     <children>
                        <Label styleClass="label-strong" text="Деталі картки" />
                        <GridPane hgap="10.0" vgap="10.0">
                           <columnConstraints>
                              <ColumnConstraints hgrow="NEVER" minWidth="150.0" />
                              <ColumnConstraints hgrow="ALWAYS" />
                           </columnConstraints>
                           <children>
                              <Label text="Гість:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                              <ComboBox fx:id="guestCombo" promptText="Оберіть гостя"
                                        GridPane.columnIndex="1" GridPane.rowIndex="0" />
                              <Label text="Рівень:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                              <ComboBox fx:id="tierCombo" promptText="Оберіть рівень"
                                        GridPane.columnIndex="1" GridPane.rowIndex="1" />
                              <Label text="Діє до:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                              <DatePicker fx:id="validUntilPicker"
                                          promptText="Дата закінчення"
                                          GridPane.columnIndex="1" GridPane.rowIndex="2" />
                              <Label text="Знижка, %:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                              <Spinner fx:id="discountSpinner" editable="true"
                                       GridPane.columnIndex="1" GridPane.rowIndex="3" />
                              <Label text="Активна:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                              <CheckBox fx:id="activeCheck" text="Картка активна"
                                        GridPane.columnIndex="1" GridPane.rowIndex="4" />
                           </children>
                        </GridPane>
                        <FlowPane alignment="CENTER" hgap="10.0" styleClass="actions-row" vgap="10.0">
                           <children>
                              <Button mnemonicParsing="false" onAction="#handleSave"
                                      styleClass="btn-primary" text="Створити картку" />
                              <Button fx:id="updateButton" mnemonicParsing="false" onAction="#handleUpdate"
                                      styleClass="btn-accent" text="Оновити" />
                              <Button fx:id="deleteButton" mnemonicParsing="false" onAction="#handleDelete"
                                      styleClass="btn-danger" text="Видалити" />
                              <Button mnemonicParsing="false" onAction="#handleClear"
                                      styleClass="btn-neutral" text="Очистити" />
                           </children>
                        </FlowPane>
                     </children>
                  </VBox>
               </content>
            </ScrollPane>
         </items>
      </SplitPane>
   </center>
</BorderPane>
